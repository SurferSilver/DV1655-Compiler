class QS {

  volatile int[] number
  volatile int size

  Start(sz : int): int {
    volatile int aux

    aux := Init(sz)
    aux := Print()
    print(9999)

    aux := size - 1
    aux := Sort(0, aux)

    aux := Print()
    return 0
  }

  Sort(left : int, right : int): int {
    volatile int v
    volatile int i
    volatile int j
    volatile int t
    volatile boolean cont1
    volatile boolean cont2
    volatile int aux

    if (left < right) {
      v := number[right]
      i := left - 1
      j := right
      cont1 := true

      while (cont1) {
        cont2 := true
        while (cont2) {
          i := i + 1
          aux := number[i]
          if (!(aux < v)) cont2 := false
        }

        cont2 := true
        while (cont2) {
          j := j - 1
          aux := number[j]
          if (!(v < aux)) cont2 := false
        }

        t := number[i]
        number[i] := number[j]
        number[j] := t

        if (j < (i + 1)) cont1 := false
      }

      number[j] := number[i]
      number[i] := number[right]
      number[right] := t
    }

    return 0
  }

  Print(): int {
    volatile int j
    j := 0

    while (j < size) {
      print(number[j])
      j := j + 1
    }
    return 0
  }

  Init(sz : int): int {
    size := sz

    number := int[20,7,12,18,2,11,6,9,19,5]

    return 0
  }
}

main(): int {
  volatile QS qs := QS()
  volatile int r := qs.Start(10)
  print(r)
  return 0
}