class Calculator {

  sumArray(values : int[]): int {
    volatile int i := 0
    volatile int total := 0

    for (i := 0, i < values.length, i := i + 1) {
      total := total + values[i]
    }

    return total
  }
}

class Counter {
  volatile int value

  init(v : int): void {
    value := v
  }

  inc(): void {
    value := value + 1
  }

  get(): int {
    return value
  }
}

main(): int {
    volatile int[] data := int[3, 1, 4, 1, 5]
    volatile int sum := Calculator().sumArray(data)

    print(sum)

    volatile Counter c := Counter()
    c.init(0)

    volatile int i := 0
    for (i := 0, i < data.length, i := i + 1) {
      c.inc()
    }

    print(c.get())
  return 0
}